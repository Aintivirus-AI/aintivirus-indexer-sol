{
  "name": "@aintivirus/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && node scripts/copy-migrations.mjs",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker-entry.ts",
    "dev:backfill": "cross-env WORKER_MODE=backfill tsx watch src/worker-entry.ts",
    "dev:live": "cross-env WORKER_MODE=live tsx watch src/worker-entry.ts",
    "dev:reconciler": "cross-env WORKER_MODE=reconciler tsx watch src/worker-entry.ts",
    "dev:servers": "concurrently -k -n api,backfill,live,reconciler -c cyan,magenta,green,yellow \"pnpm dev\" \"pnpm dev:backfill\" \"pnpm dev:live\" \"pnpm dev:reconciler\"",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker-entry.js",
    "start:api": "node dist/server.js",
    "start:backfill": "cross-env WORKER_MODE=backfill node dist/worker-entry.js",
    "start:live": "cross-env WORKER_MODE=live node dist/worker-entry.js",
    "start:reconciler": "cross-env WORKER_MODE=reconciler node dist/worker-entry.js",
    "start:servers": "concurrently -k -n api,backfill,live,reconciler -c cyan,magenta,green,yellow \"pnpm start:api\" \"pnpm start:backfill\" \"pnpm start:live\" \"pnpm start:reconciler\"",
    "migrate": "tsx src/db/run-migrations.ts",
    "reset": "tsx src/db/reset-db.ts",
    "cli": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.98.0",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
